# Copy this file to ".env" for LOCAL runs and fill in real values.
# On GitHub these same names are set as encrypted Actions Secrets instead.
# NEVER commit the real .env file (it is git-ignored).

# --- TNP portal login ---
TNP_USERNAME=your_username
TNP_PASSWORD=your_password

# Placement year to track for "Recent Jobs" (must match the site's dropdown).
TNP_PLACEMENT_YEAR=2026-27

# --- Telegram delivery ---
# Create a bot via @BotFather to get the token.
TELEGRAM_BOT_TOKEN=123456789:AA...your_bot_token...
# Numeric chat id of you or the group. Find it with:  python watcher.py --chatid
TELEGRAM_CHAT_ID=123456789
